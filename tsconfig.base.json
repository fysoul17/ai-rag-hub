{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",

    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "allowJs": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    "jsx": "react-jsx",
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@autonomy/shared": ["./packages/shared/src/index.ts"],
      "@autonomy/shared/*": ["./packages/shared/src/*"],
      "@autonomy/agent-manager": ["./packages/agent-manager/src/index.ts"],
      "@autonomy/agent-manager/*": ["./packages/agent-manager/src/*"],
      "@pyx-memory/shared": ["./vendor/pyx-memory/packages/shared/src/index.ts"],
      "@pyx-memory/shared/*": ["./vendor/pyx-memory/packages/shared/src/*"],
      "@pyx-memory/core": ["./vendor/pyx-memory/packages/core/src/index.ts"],
      "@pyx-memory/core/*": ["./vendor/pyx-memory/packages/core/src/*"],
      "@pyx-memory/client": ["./vendor/pyx-memory/packages/client/src/index.ts"],
      "@pyx-memory/client/*": ["./vendor/pyx-memory/packages/client/src/*"],
      "@autonomy/conductor": ["./packages/conductor/src/index.ts"],
      "@autonomy/conductor/*": ["./packages/conductor/src/*"],
      "@autonomy/cron-manager": ["./packages/cron-manager/src/index.ts"],
      "@autonomy/cron-manager/*": ["./packages/cron-manager/src/*"],
      "@autonomy/server": ["./packages/server/src/index.ts"],
      "@autonomy/server/*": ["./packages/server/src/*"],
      "@autonomy/control-plane": ["./packages/control-plane/src/index.ts"],
      "@autonomy/control-plane/*": ["./packages/control-plane/src/*"],
      "@autonomy/plugin-system": ["./packages/plugin-system/src/index.ts"],
      "@autonomy/plugin-system/*": ["./packages/plugin-system/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".turbo"]
}
